# SQLite (dev default). For MSSQL swap provider in prisma/schema.prisma and use:
# DATABASE_URL="sqlserver://localhost:1433;database=fdl_create;user=sa;password=YourStrong!Passw0rd;trustServerCertificate=true;encrypt=true"
DATABASE_URL="file:./dev.db"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-random-32-byte-base64"
AUTH_URL="http://localhost:3000"

# Claude (optional — for ai-schema-designer / ai-content-assistant)
ANTHROPIC_API_KEY=""
