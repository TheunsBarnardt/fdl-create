// Lattice / fdl-create — schema-as-data runtime + Auth.js
// Collection/Record store the *meta-schema*; tenant data lives in Record.data (JSON).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---- Auth.js (NextAuth v5) ----
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  role          String    @default("editor") // admin | editor | viewer
  disabledAt    DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())

  accounts Account[]
  sessions Session[]
  audits   AiAuditLog[]
  tokens   ApiToken[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ---- Schema-as-data (Lattice runtime) ----
model Collection {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  description String?
  schema      String   // JSON: { fields: [{name,type,required,unique,default,...}] }
  aiOptIn     Boolean  @default(false)
  redactions  String?  // JSON array of field names
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  records Record[]
}

model Record {
  id           String   @id @default(cuid())
  collectionId String
  data         String   // JSON payload matching Collection.schema
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  @@index([collectionId])
}

model Page {
  id                String   @id @default(cuid())
  slug              String   @unique
  title             String
  tree              String   // JSON block tree
  published         Boolean  @default(false)
  themeId           String?  // links to Theme.id
  params            String?  // JSON: string[] — e.g. ["id"] for /customers/[id]
  defaultCollection String?  // Collection.name — block placements on this page must bind to this or a related collection
  seo               String?  // JSON: { metaTitle, metaDescription, ogTitle, ogDescription, ogImage, canonicalUrl, noIndex }
  renderMode        String   @default("dynamic") // 'dynamic' | 'static' — static pages are pre-rendered and invalidated via the dep graph
  lastBuiltAt       DateTime? // populated by the publish pass for static pages
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  navItems     NavItem[]
  dependencies PageDependency[]
}

// Populated by the publish pass for static pages.
// recordId = null means "any row in this collection" (covers query-list blocks).
model PageDependency {
  id         String   @id @default(cuid())
  pageId     String
  collection String
  recordId   String?
  createdAt  DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  @@index([pageId])
  @@index([collection, recordId])
}

model CustomBlock {
  id          String   @id @default(cuid())
  name        String   @unique
  title       String?
  description String?
  source      String   // pasted JSX/HTML — pure template with {{slot}} placeholders
  shape       String   @default("single") // 'single' | 'list' — list blocks use {{#each rows}}...{{/each}}
  slotSchema  String?  // JSON: { [slotName]: { type: 'string'|'number'|'date'|'boolean'|'link'|'image'|'richtext', format?, fallback? } }
  category    String?
  themeId     String?  // optional — preset/theme applied for typography bindings
  createdAt   DateTime @default(now())
}

model Theme {
  id        String   @id @default(cuid())
  name      String   @unique
  tokens    String   // JSON design tokens
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Preset {
  id        String   @id @default(cuid())
  name      String
  tokens    String   // JSON design tokens (color subset)
  createdAt DateTime @default(now())
}

model VariableCollection {
  id        String     @id @default(cuid())
  name      String     @unique
  label     String
  order     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  variables Variable[]
}

model Variable {
  id           String    @id @default(cuid())
  collectionId String
  name         String    // e.g., "colors/primary/base" (with "/" for grouping)
  type         String    // "color" | "number" | "string" | "boolean" | "dimension"
  value        String    // JSON: single value or { light: ..., dark: ... }
  description  String?
  order        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  collection VariableCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  @@unique([collectionId, name])
  @@index([collectionId])
}

model AssetCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  parentId  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  parent   AssetCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children AssetCategory[] @relation("CategoryTree")
  assets   Asset[]
}

model Asset {
  id         String   @id @default(cuid())
  categoryId String?
  name       String
  filename   String   @unique
  url        String
  mimeType   String
  size       Int
  width      Int?
  height     Int?
  alt        String?
  focalX     Float    @default(50)
  focalY     Float    @default(50)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category AssetCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  @@index([categoryId])
}

model DocumentCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  parentId  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  parent    DocumentCategory?  @relation("DocumentCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  DocumentCategory[] @relation("DocumentCategoryTree")
  documents Document[]
}

model Document {
  id          String   @id @default(cuid())
  categoryId  String?
  name        String
  filename    String   @unique
  url         String
  mimeType    String
  size        Int
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category DocumentCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  @@index([categoryId])
}

model AiAuditLog {
  id         String   @id @default(cuid())
  userId     String?
  collection String?
  action     String   // read | write | suggest
  scope      String   // JSON: fields touched, redaction summary
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([collection])
}

// ---- Navigation & Footer ----
model Navigation {
  id        String   @id @default(cuid())
  items     NavItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NavItem {
  id            String   @id @default(cuid())
  navigationId  String
  parentId      String?
  label         String
  navType       String   @default("flat")  // "flat" | "dropdown" | "mega"
  pageId        String?
  customUrl     String?
  openInNewTab  Boolean  @default(false)
  columns       Int?     // Number of columns for mega-nav
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  navigation Navigation @relation(fields: [navigationId], references: [id], onDelete: Cascade)
  parent     NavItem?   @relation("NavItemChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children   NavItem[]  @relation("NavItemChildren")
  page       Page?      @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@index([navigationId])
  @@index([parentId])
  @@index([pageId])
}

model Footer {
  id        String        @id @default(cuid())
  type      String        @default("simple")  // "simple" | "columns"
  columns   FooterColumn[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model FooterColumn {
  id        String   @id @default(cuid())
  footerId  String
  title     String
  items     String   // JSON: [{ label, url }]
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  footer Footer @relation(fields: [footerId], references: [id], onDelete: Cascade)
  @@index([footerId])
}

// ---- Stored Procedures ----
model ProcedureGroup {
  id        String            @id @default(cuid())
  name      String            @unique  // display name, e.g. "Accounts"
  order     Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  procedures StoredProcedure[]
}

model StoredProcedure {
  id        String              @id @default(cuid())
  groupId   String
  name      String              // short name, e.g. "Get"
  signature String              @default("") // e.g. "dbo.Accounts_Get"
  body      String              @default("") // full CREATE OR ALTER PROCEDURE … body
  params    String              @default("[]") // JSON: [{ name, sqlType, direction, defaultValue, testValue }]
  status    String              @default("draft") // "draft" | "saved" | "deployed"
  boundTo   String?             // Collection.name — data source binding
  order     Int                 @default(0)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  group     ProcedureGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  revisions ProcedureRevision[]

  @@unique([groupId, name])
  @@index([groupId])
}

model ProcedureRevision {
  id          String   @id @default(cuid())
  procedureId String
  body        String
  params      String
  createdAt   DateTime @default(now())

  procedure StoredProcedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  @@index([procedureId])
}

// ---- Platform observability + Management API ----
model ApiRequestLog {
  id         String   @id @default(cuid())
  method     String   // GET | POST | PATCH | DELETE
  path       String   // e.g. /api/collections/customers/records
  status     Int
  durationMs Int
  userId     String?
  tokenId    String?  // ApiToken.id when auth was a PAT
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([status])
}

model PageView {
  id          String   @id @default(cuid())
  path        String
  referer     String?
  country     String?  // best-effort from cf-ipcountry / x-vercel-ip-country header
  device      String?  // desktop | mobile | tablet
  browser     String?  // Chrome | Safari | Firefox | Edge | Other
  os          String?
  bytes       Int?     // transferSize from PerformanceNavigationTiming
  durationMs  Int?     // navigation timing (responseEnd - startTime)
  ipHash      String?  // sha256(ip + workspace salt) — never raw IP
  userAgent   String?
  sessionId   String?  // rotated per workspace salt
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([country])
}

model VitalsEvent {
  id        String   @id @default(cuid())
  metric    String   // LCP | FID | CLS | INP | TTFB | FCP
  value     Float
  rating    String   // good | needs-improvement | poor
  path      String
  navId     String?  // web-vitals Metric.navigationType
  device    String?
  browser   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([metric])
  @@index([path])
}

model LighthouseRun {
  id            String   @id @default(cuid())
  url           String
  strategy      String   @default("desktop") // desktop | mobile
  performance   Int
  accessibility Int
  bestPractices Int
  seo           Int
  lcpMs         Int?
  clsScore      Float?
  tbtMs         Int?
  source        String   @default("psi")     // psi | lhci | manual
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([url])
}

model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  name       String
  prefix     String    @unique // first 12 chars — shown in UI/logs
  tokenHash  String    // sha256(full token)
  scopes     String    // JSON: string[]
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}
