// Lattice / fdl-create — schema-as-data runtime + Auth.js
// Collection/Record store the *meta-schema*; tenant data lives in Record.data (JSON).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---- Auth.js (NextAuth v5) ----
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  role          String    @default("editor") // admin | editor | viewer
  disabledAt    DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())

  accounts Account[]
  sessions Session[]
  audits   AiAuditLog[]
  tokens   ApiToken[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ---- Schema-as-data (Lattice runtime) ----
model Collection {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  description String?
  schema      String   // JSON: { fields: [{name,type,required,unique,default,...}] }
  aiOptIn     Boolean  @default(false)
  redactions  String?  // JSON array of field names
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  records Record[]
}

model Record {
  id           String   @id @default(cuid())
  collectionId String
  data         String   // JSON payload matching Collection.schema
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  @@index([collectionId])
}

model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  tree      String   // JSON block tree
  published Boolean  @default(false)
  themeId   String?  // links to Theme.id
  params    String?  // JSON: string[] — e.g. ["id"] for /customers/[id]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomBlock {
  id          String   @id @default(cuid())
  name        String   @unique
  title       String?
  description String?
  source      String   // pasted JSX/HTML
  slotMap     String?  // JSON { slotName: fieldName }
  collection  String?
  category    String?
  createdAt   DateTime @default(now())
}

model Theme {
  id        String   @id @default(cuid())
  name      String   @unique
  tokens    String   // JSON design tokens
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Preset {
  id        String   @id @default(cuid())
  name      String
  tokens    String   // JSON design tokens (color subset)
  createdAt DateTime @default(now())
}

model VariableCollection {
  id        String     @id @default(cuid())
  name      String     @unique
  label     String
  order     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  variables Variable[]
}

model Variable {
  id           String    @id @default(cuid())
  collectionId String
  name         String    // e.g., "colors/primary/base" (with "/" for grouping)
  type         String    // "color" | "number" | "string" | "boolean" | "dimension"
  value        String    // JSON: single value or { light: ..., dark: ... }
  description  String?
  order        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  collection VariableCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  @@unique([collectionId, name])
  @@index([collectionId])
}

model AssetCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  parentId  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  parent   AssetCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children AssetCategory[] @relation("CategoryTree")
  assets   Asset[]
}

model Asset {
  id         String   @id @default(cuid())
  categoryId String?
  name       String
  filename   String   @unique
  url        String
  mimeType   String
  size       Int
  width      Int?
  height     Int?
  alt        String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category AssetCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  @@index([categoryId])
}

model AiAuditLog {
  id         String   @id @default(cuid())
  userId     String?
  collection String?
  action     String   // read | write | suggest
  scope      String   // JSON: fields touched, redaction summary
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([collection])
}

// ---- Platform observability + Management API ----
model ApiRequestLog {
  id         String   @id @default(cuid())
  method     String   // GET | POST | PATCH | DELETE
  path       String   // e.g. /api/collections/customers/records
  status     Int
  durationMs Int
  userId     String?
  tokenId    String?  // ApiToken.id when auth was a PAT
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([status])
}

model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  name       String
  prefix     String    @unique // first 12 chars — shown in UI/logs
  tokenHash  String    // sha256(full token)
  scopes     String    // JSON: string[]
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}
